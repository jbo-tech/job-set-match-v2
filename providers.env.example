# Central LLM provider API keys — template
# Installed to: ~/.config/llm-provider-keys/providers.env (by install.sh)
# Permissions: 600
#
# Only fill in the providers you use in config.yaml.
# The app routes to providers based on model_id prefix.

ANTHROPIC_API_KEY=sk-ant-...
BRAVE_API_KEY=BSA...
# OPENAI_API_KEY=sk-...
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GOOGLE_API_KEY=
