# ─── Obsidian vault ───────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=/home/user/Obsidian/career

# ─── Sécurité ────────────────────────────────────────────────────
AUTH_TOKEN=change-me-random-string

# ─── API keys (Anthropic obligatoire, les autres optionnels) ─────
ANTHROPIC_API_KEY=sk-ant-...
BRAVE_API_KEY=BSA...

# Providers optionnels — requis seulement si un *_MODEL pointe dessus
# OPENAI_API_KEY=sk-...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...
# GROQ_API_KEY=gsk_...
# GOOGLE_API_KEY=...

# ─── Modèles LLM ────────────────────────────────────────────────
# Modèle par défaut (utilisé si pas d'override par service)
DEFAULT_MODEL=claude-sonnet-4-20250514

# Overrides par service (laisser vide = fallback sur DEFAULT_MODEL)
# Exemples : claude-haiku-3-20250414, gpt-4o-mini, mistral-large-latest
# ANALYSIS_MODEL=
# COMPANY_MODEL=
# GENERATION_MODEL=

# Préfixes reconnus par la factory :
#   claude-*     → Anthropic (SDK natif, prompt cache préservé)
#   gpt-*, o1-*, o3-*, o4-*, chatgpt-* → OpenAI
#   mistral*     → Mistral (api.mistral.ai)
#   deepseek*    → DeepSeek (api.deepseek.com)
#   groq/*       → Groq (api.groq.com) — ex: groq/llama-3.1-70b
#   gemini*      → Google (generativelanguage.googleapis.com)

# ─── Paramètres LLM ─────────────────────────────────────────────
# MAX_TOKENS=8192
# ANALYSIS_TEMPERATURE=0.2
# GENERATION_TEMPERATURE=0.7

# ─── Score gate ──────────────────────────────────────────────────
# 0 = pas de seuil, se fier à la décision de Claude
# SCORE_THRESHOLD=0

# ─── Serveur ─────────────────────────────────────────────────────
# HOST=127.0.0.1
# PORT=8000
