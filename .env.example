# ─── Secrets uniquement — la config métier (vault, modèles, serveur) est dans config.yaml ───

# ─── Sécurité ────────────────────────────────────────────────────
# Token partagé entre l'extension Firefox et FastAPI
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
# Caractères ASCII uniquement (en-têtes HTTP) — le plugin rejette le reste.
AUTH_TOKEN=change-me-random-string

# ─── API keys (Anthropic obligatoire, les autres optionnels) ─────
ANTHROPIC_API_KEY=sk-ant-...
BRAVE_API_KEY=BSA...

# Providers optionnels — requis seulement si un modèle dans config.yaml pointe dessus
# OPENAI_API_KEY=sk-...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...
# GROQ_API_KEY=gsk_...
# GOOGLE_API_KEY=...
