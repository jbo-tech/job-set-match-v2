# Project-specific config only — provider API keys come from the central store.
# See install.sh or README for setup.
# chmod 600 .env

# ─── Obsidian ────────────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ─── Security ────────────────────────────────────────────────────
# Shared token between Firefox extension and FastAPI
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=change-me-random-string

# ─── Playwright ───────────────────────────────────────────────────
# Optionnel. Chemin vers un chromium système (si le bundle Playwright
# n'est pas disponible pour votre OS, ex: Ubuntu trop récent).
# Exemples : /snap/bin/chromium, /usr/bin/chromium-browser
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
